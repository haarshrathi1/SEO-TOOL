CLIENT_ID=your_google_oauth_client_id
CLIENT_SECRET=your_google_oauth_client_secret
REDIRECT_URI=https://your-backend.onrender.com/auth/google/callback
FRONTEND_URL=https://seotool.harshrathi.com
ALLOWED_ORIGINS=
JWT_SECRET=replace_with_a_long_random_secret
COOKIE_SAME_SITE=lax
ADMIN_EMAIL=your_admin_google_email@example.com
ADMIN_EMAILS=
DEV_ADMIN_BYPASS=false
DISABLE_SERVICE_ACCOUNT=true
GEMINI_API_KEY=your_gemini_api_key
GEMINI_KEYWORD_API_KEY=your_gemini_keyword_api_key
